# Anthropic — used for LLM scoring and drafting via LiteLLM
ANTHROPIC_API_KEY=sk-ant-...

# LLM model selection
LLM_SCORING_MODEL=anthropic/claude-haiku-4-5
LLM_DRAFTING_MODEL=anthropic/claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Telegram — bot token from @BotFather, chat_id of your personal chat
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Reddit (PRAW) — for posting approved replies
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Turso (libSQL) — database
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_token

# Scheduler — cron expression + timezone
SCAN_CRON=0 9,18 * * *
TIMEZONE=America/Los_Angeles
